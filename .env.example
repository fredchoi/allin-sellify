# ===========================
# 서버 설정
# ===========================
PORT=3001
NODE_ENV=development

# ===========================
# 데이터베이스 (TimescaleDB)
# ===========================
DATABASE_URL=postgresql://sellify:sellify_dev@localhost:5432/sellify_dev

# ===========================
# Redis (BullMQ + 캐시 + 분산 락)
# ===========================
REDIS_URL=redis://localhost:6379

# ===========================
# Elasticsearch (한국어 nori 플러그인 포함)
# ===========================
ELASTICSEARCH_URL=http://localhost:9200

# ===========================
# 키워드 어댑터 모드
# mock: 실제 API 없이 테스트 가능
# real: 네이버 API 실제 호출
# ===========================
KEYWORD_ADAPTER_MODE=mock

# ===========================
# 네이버 검색광고 API (KEYWORD_ADAPTER_MODE=real 시 필수)
# https://naver.github.io/searchad-apidoc/
# ===========================
NAVER_AD_API_KEY=
NAVER_AD_SECRET=
NAVER_AD_CUSTOMER_ID=

# ===========================
# 네이버 DataLab API (KEYWORD_ADAPTER_MODE=real 시 필수)
# https://developers.naver.com/docs/serviceapi/datalab/search/search.md
# ===========================
NAVER_DATALAB_CLIENT_ID=
NAVER_DATALAB_CLIENT_SECRET=

# ===========================
# Sentry 에러 모니터링
# https://sentry.io 에서 프로젝트 생성 후 DSN 발급
# 미설정 시 에러 모니터링 비활성화
# ===========================
SENTRY_DSN=

# ===========================
# JWT 인증
# ===========================
JWT_SECRET=your-secret-at-least-32-characters-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ===========================
# 네이버 스마트스토어 커머스 API
# ===========================
NAVER_COMMERCE_CLIENT_ID=
NAVER_COMMERCE_CLIENT_SECRET=

# ===========================
# 마켓플레이스 어댑터 모드
# mock: 실제 API 없이 테스트 가능
# real: 마켓 API 실제 호출
# ===========================
MARKETPLACE_ADAPTER_MODE=mock

# ===========================
# 도매 어댑터
# mock: 목업 데이터 사용
# domeggook: 도매꾹 API 실제 호출
# ===========================
WHOLESALE_ADAPTER=mock
DOMEGGOOK_API_KEY=

# ===========================
# AI (Claude API)
# ===========================
ANTHROPIC_API_KEY=

# ===========================
# SNS 콘텐츠 발행 모드
# mock: 실제 API 없이 테스트
# real: Meta/X API 실제 호출
# ===========================
SNS_API_MODE=mock

# ===========================
# 데모 모드: API 키 없이 전체 파이프라인 체험
# ===========================
DEMO_MODE=false
